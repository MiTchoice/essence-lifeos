PORT=5000
MONGODB_URI=mongodb://localhost:27017/lifeos
# OR use MongoDB Atlas free tier:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/lifeos

# AI Integration (choose one — both are FREE)
# Option 1: OpenRouter (free models like mistralai/mistral-7b-instruct)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Option 2: HuggingFace Inference API (free tier)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Set to "openrouter" | "huggingface" | "mock"
AI_PROVIDER=mock
